# Copy this file to .env and fill in your values.

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=8883
MQTT_USE_TLS=true

# ── Agent Identity ────────────────────────────────────────────────────────────
# Topics are auto-built: {MQTT_BASE_TOPIC}/os/{AGENT_NAME}/cmd|output|cancel
# Must match the os_terminal device configured in the web app.
MQTT_BASE_TOPIC=Mylab/smarthome
AGENT_NAME=office-pc

# ── Timeout ───────────────────────────────────────────────────────────────────
COMMAND_TIMEOUT=60

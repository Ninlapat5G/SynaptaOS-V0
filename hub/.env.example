# Copy this file to .env and fill in your values.

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.opentyphoon.ai/v1
LLM_MODEL=typhoon-v2.5-30b-a3b-instruct

# ── Web Search (optional — enables CommandAgent to search for command syntax) ─
SERPER_API_KEY=

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=8883
MQTT_USE_TLS=true

# ── Agent Identity ────────────────────────────────────────────────────────────
# Topics are auto-built: {MQTT_BASE_TOPIC}/hub/{AGENT_NAME}/cmd|output|cancel
# Must match the hub device configured in the web app.
MQTT_BASE_TOPIC=Mylab/smarthome
AGENT_NAME=office-pc

# ── Timeout ───────────────────────────────────────────────────────────────────
COMMAND_TIMEOUT=60

# ── Disable CrewAI telemetry ──────────────────────────────────────────────────
CREWAI_TRACING_ENABLED=false
OTEL_SDK_DISABLED=true

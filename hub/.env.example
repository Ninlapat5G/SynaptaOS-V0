# Copy this file to .env and fill in your values.

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.opentyphoon.ai/v1
LLM_MODEL=typhoon-v2.5-30b-a3b-instruct

# ── Web Search (optional — enables CommandAgent to search for command syntax) ─
SERPER_API_KEY=

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USE_TLS=false

# ── Topics (must match the Hub device in the web app) ────────────────────────
# Web app publishes task here  →  agent subscribes
MQTT_SUB_TOPIC=hub/office-pc/cmd
# Agent streams output here   →  web app subscribes
MQTT_PUB_TOPIC=hub/office-pc/output

# ── Timeout ───────────────────────────────────────────────────────────────────
COMMAND_TIMEOUT=60

# Copy this file to .env and fill in your values.

# LLM — any OpenAI-compatible endpoint (OpenAI, Typhoon, Ollama, etc.)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Ports
MCP_PORT=8000   # REST + FastMCP HTTP (web app points here)
WS_PORT=8001    # WebSocket (terminal agents connect here)

# Seconds to wait for terminal output before timing out
COMMAND_TIMEOUT=30
